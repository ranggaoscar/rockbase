# Copy to .env.staging.local and replace every placeholder locally.
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-staging-password
BOOTSTRAP_ADMIN_TOKEN=replace-with-a-random-bootstrap-token-of-at-least-24-characters
# Optional server-side local webhook integration; never expose this token to the frontend.
ROCKBASE_LOCAL_WEBHOOK_URL=
ROCKBASE_LOCAL_WEBHOOK_TOKEN=
