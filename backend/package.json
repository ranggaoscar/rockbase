{
  "name": "rock-base-backend",
  "version": "1.0.0",
  "description": "ROCK BASE Backend - WARNING: Never run 'prisma migrate reset' manually unless you have a verified backup in the /backups folder.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec \"ts-node --transpile-only src/server.ts\"",
    "worker": "nodemon --exec \"ts-node --transpile-only src/worker.ts\"",
    "seed": "ts-node src/scripts/seed.ts",
    "queue:clear-posting": "ts-node --transpile-only src/scripts/clear-posting-queue.ts",
    "queue:requeue-pending": "ts-node --transpile-only src/scripts/requeue-pending-posts.ts",
    "queue:reconcile": "node dist/scripts/queue-reconcile.js",
    "test:queue-runtime-safety": "ts-node --files src/scripts/queue-runtime-safety-test.ts",
    "migrate-safe": "ts-node src/scripts/backup-now.ts && npx prisma migrate dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.4.1",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.76.4",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/socket.io": "^3.0.1",
    "nodemon": "^3.1.14",
    "prisma": "^6.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
