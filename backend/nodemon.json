{
  "watch": ["src"],
  "ext": "ts,js,json",
  "ignore": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/scripts/**",
    "uploads/**",
    "logs/**",
    "prisma/migrations/**",
    "backups/**",
    "node_modules/**",
    "dev.db",
    "dev.db.backup"
  ],
  "delay": 2000,
  "verbose": true
}
