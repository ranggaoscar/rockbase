# ==========================================
# SocialCommand - Backend Environment Variables
# ==========================================

# SERVER CONFIGURATION
PORT=3000

# FRONTEND URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# DATABASE (SQLite)
# Must match backend/prisma/schema.prisma provider = "sqlite"
DATABASE_URL="file:./dev.db"

# REDIS & BULLMQ (Queue System)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

# SESSION HEALTH CHECK
# Keep this small: each checked Instagram account opens a browser context.
MAX_BULK_SESSION_CHECK=3
SESSION_HEALTH_CHECK_CONCURRENCY=2

# JWT AUTH
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_here_change_this_in_production"
JWT_EXPIRES_IN="24h"

# SECURITY (AES-256 Cookie Encryption)
# MUST BE EXACTLY 32 BYTES (64 HEX CHARACTERS)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# AI GENERATOR
# Get this from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-flash-latest"

# AI VISION PREVIEW (Compose preview only)
# Optional: auto uses Gemini first, then OpenAI if Gemini is not configured.
VISION_PROVIDER="auto"
GEMINI_VISION_MODEL="gemini-flash-latest"
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_VISION_MODEL="gpt-4o-mini"
